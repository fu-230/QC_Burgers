Cell[BoxData[{
 RowBox[{
  RowBox[{"xGrid", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"xMin", ",", "xMax", ",", "dx"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"phi0", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", 
    RowBox[{"i", "<=", "xgr"}], ",", 
    RowBox[{"i", "++"}], ",", 
    RowBox[{"AppendTo", "[", 
