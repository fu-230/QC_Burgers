        RowBox[{"[", "xgr", "]"}], "]"}], "=", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"(", 
          RowBox[{"2.", "*", 
           RowBox[{"nu", "/", 
            RowBox[{"(", 
             RowBox[{"2.", "*", "dx"}], ")"}]}]}], ")"}]}], "*", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"results", "[", 
             RowBox[{"[", "t", "]"}], "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}], "-", 
           RowBox[{
            RowBox[{"results", "[", 
             RowBox[{"[", "t", "]"}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{"xgr", "-", "1"}], "]"}], "]"}]}], ")"}], "/", 
         "hom"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"u", "=", "uNew"}], ";", "\[IndentingNewLine]", 
      RowBox[{"approxu", "=", "approxuNew"}], ";", "\[IndentingNewLine]", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"uresults", ",", "u"}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"approxuresults", ",", "approxu"}], "]"}], ";"}]}], "]"}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
