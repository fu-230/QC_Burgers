Cell[BoxData[{
 RowBox[{
  RowBox[{"logphiinidata", "[", "n_", "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"Xi", "[", "\"\<Values\>\"", "]"}], "[", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"2", "*", "xgr"}], "+", "1"}], "]"}], "]"}], "+", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Xi", "[", "\"\<Values\>\"", "]"}], "[", 
        RowBox[{"[", "i", "]"}], "]"}], "*", 
       RowBox[{"Sin", "[", 
        RowBox[{"2", "*", "Pi", "*", "i", "*", 
         RowBox[{"n", "/", 
          RowBox[{"(", 
           RowBox[{"xgr", "-", "1"}], ")"}]}]}], "]"}]}], "+", 
      RowBox[{
       RowBox[{
        RowBox[{"Xi", "[", "\"\<Values\>\"", "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"i", "+", "xgr"}], "]"}], "]"}], "*", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", "*", "Pi", "*", "i", "*", 
         RowBox[{"n", "/", 
          RowBox[{"(", 
           RowBox[{"xgr", "-", "1"}], ")"}]}]}], "]"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "5"}], "}"}]}], "]"}]}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"data", "=", 
    RowBox[{"Array", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"logphiinidata", "[", 
        RowBox[{"#", "-", "1"}], "]"}], "&"}], ",", "xgr"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Export", "[", 
    RowBox[{"\"\<logphiini.dat\>\"", ",", "data"}], "]"}], ";"}], 
  " "}]}], "Input",
 CellChangeTimes->{{3.981754881236168*^9, 3.981754883156007*^9}, {
  3.981754916099051*^9, 3.981754927671822*^9}, {3.982271468298894*^9, 
  3.98227148067488*^9}},ExpressionUUID->"9bf6919c-8e95-4b16-8f10-\
97d82fe707a6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"itpphiini", ",", "hom"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"dataimp", "=", 
   RowBox[{"Import", "[", "\"\<logphiini.dat\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dataimpext", "=", 
   RowBox[{"Append", "[", 
    RowBox[{"dataimp", ",", 
     RowBox[{"dataimp", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"itpimpdata", "=", 
   RowBox[{"Interpolation", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"j", ",", 
         RowBox[{"dataimpext", "[", 
          RowBox[{"[", "j", "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "xgr"}], "}"}]}], "]"}], ",", 
     RowBox[{"InterpolationOrder", "->", "3"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"itpphiini", "[", 
     RowBox[{"x_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Exp", "[", 
     RowBox[{"-", 
      RowBox[{
       RowBox[{"itpimpdata", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", "-", "xMin"}], ")"}], "/", "dx"}], "+", "1"}], "]"}], 
       "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"hom", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{"itpphiini", "[", 
         RowBox[{"xMin", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"i", "-", "1"}], ")"}], "*", "dx"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "xgr"}], "}"}]}], "]"}], "/", "xgr"}], 
     "/", "BoxSize"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"thickness", "=", "0.04"}], ";", 
  RowBox[{"colorIni", "=", "gray"}], ";", 
  RowBox[{"colorFin", "=", "sora"}], ";"}], "\n", 
 RowBox[{"graph1", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"hom", ",", 
      RowBox[{"itpphiini", "[", "x", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "xMin", ",", "xMax"}], "}"}], ",", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{
      "\"\<x\>\"", ",", "\"\<\!\(\*SubscriptBox[\(\[Psi]\), \(ini\)]\)\>\""}],
       "}"}]}], ",", 
    RowBox[{"BaseStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"FontSize", "->", "12"}], ",", 
       RowBox[{"FontFamily", "->", "\"\<Latin Modern Roman\>\""}]}], "}"}]}], 
    ",", 
    RowBox[{"ImageSize", "->", "300"}], ",", 
    RowBox[{"PlotRange", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", "5"}], "}"}]}], ",", 
    RowBox[{"PlotStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Thickness", "[", 
          RowBox[{"thickness", "/", "5"}], "]"}], ",", "sakura"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Thickness", "[", 
          RowBox[{"thickness", "/", "5"}], "]"}], ",", "aomidori"}], "}"}]}], 
      "}"}]}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9817549441435337`*^9, 3.981755001246463*^9}, {
  3.981759649949255*^9, 3.9817596513839703`*^9}, {3.9817596883287888`*^9, 
