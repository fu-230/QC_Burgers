Cell[BoxData[{
 RowBox[{
  RowBox[{"Reynolds", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Reynolds2", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"t", "=", "1"}], ",", 
    RowBox[{"t", "<=", "tgr"}], ",", 
    RowBox[{"t", "++"}], ",", 
    RowBox[{
     RowBox[{"urms2", "=", "0"}], ";", "\[IndentingNewLine]", 
     RowBox[{"dudxrms2", "=", "0"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "<=", "xgr"}], ",", 
       RowBox[{"i", "++"}], ",", 
       RowBox[{
        RowBox[{"urms2", "=", 
         RowBox[{"urms2", "+", 
          RowBox[{
           RowBox[{
            RowBox[{"uresults", "[", 
             RowBox[{"[", "t", "]"}], "]"}], "[", 
            RowBox[{"[", "i", "]"}], "]"}], "^", "2"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"i", "==", "1"}], "||", 
             RowBox[{"i", "==", "xgr"}]}], ")"}]}], ",", 
          RowBox[{"dudxrms2", "=", 
           RowBox[{"dudxrms2", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "/", "4."}], ")"}], "*", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"uresults", "[", 
                   RowBox[{"[", "t", "]"}], "]"}], "[", 
                  RowBox[{"[", 
                   RowBox[{"i", "+", "1"}], "]"}], "]"}], "-", 
                 RowBox[{
                  RowBox[{"uresults", "[", 
                   RowBox[{"[", "t", "]"}], "]"}], "[", 
                  RowBox[{"[", 
                   RowBox[{"i", "-", "1"}], "]"}], "]"}]}], ")"}], "^", "2"}],
               "/", 
              RowBox[{"dx", "^", "2"}]}]}]}]}]}], "]"}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"urms", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"urms2", "/", "xgr"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"dudxrms", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"dudxrms2", "/", 
        RowBox[{"(", 
         RowBox[{"xgr", "-", "2"}], ")"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"Reynolds", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"tMin", "+", 
          RowBox[{"t", "*", "dt"}]}], ",", 
         RowBox[{
          RowBox[{"urms", "^", "2"}], "/", 
          RowBox[{"(", 
           RowBox[{"nu", "*", "dudxrms"}], ")"}]}]}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"Reynolds2", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"tMin", "+", 
          RowBox[{"t", "*", "dt"}]}], ",", 
         RowBox[{
          RowBox[{"urms", "^", "4"}], "/", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"nu", "*", "dudxrms"}], ")"}], "^", "2"}]}]}], "}"}]}], 
      "]"}], ";"}]}], "]"}], ";"}]}], "Input",
