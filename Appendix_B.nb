Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"IC1", "[", "x_", "]"}], ":=", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Min", "[", 
       RowBox[{"x", ",", "0"}], "]"}]}], "/", 
     RowBox[{"(", 
      RowBox[{"2.", "*", "nu"}], ")"}]}], "]"}]}], 
  RowBox[{"(*", "Shock1", "*)"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"IC2", "[", "x_", "]"}], ":=", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Min", "[", 
       RowBox[{
        RowBox[{"x", "+", "1"}], ",", 
        RowBox[{"Max", "[", 
         RowBox[{
          RowBox[{"0.75", "+", 
           RowBox[{"0.5", "*", "x"}], "-", 
           RowBox[{"0.25", "*", 
            RowBox[{"x", "^", "2"}]}]}], ",", 
          RowBox[{
           RowBox[{"0.5", "*", "x"}], "+", "0.5"}]}], "]"}], ",", "1"}], 
       "]"}]}], "/", 
     RowBox[{"(", 
      RowBox[{"2.", "*", "nu"}], ")"}]}], "]"}]}], " ", 
  RowBox[{"(*", "Shock2", "*)"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"IC3", "[", "x_", "]"}], ":=", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Max", "[", 
       RowBox[{"0", ",", 
        RowBox[{"Min", "[", 
         RowBox[{
          RowBox[{"0.25", "+", 
           RowBox[{"0.5", "*", "x"}], "+", 
           RowBox[{"0.25", "*", 
            RowBox[{"x", "^", "2"}]}]}], ",", 
          RowBox[{
           RowBox[{"0.5", "*", "x"}], "+", "0.5"}]}], "]"}], ",", "x"}], 
       "]"}]}], "/", 
     RowBox[{"(", 
      RowBox[{"2.", "*", "nu"}], ")"}]}], "]"}]}], " ", 
  RowBox[{"(*", 
   RowBox[{"Dilution", " ", "fan"}], "*)"}], ";"}]}], "Input",
 CellChangeTimes->{{3.981750342579918*^9, 3.981750377053596*^9}, {
  3.98175041463372*^9, 3.9817504629434967`*^9}, {3.981750644453537*^9, 
