Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"xGrid", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"xMin", ",", "xMax", ",", "dx"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"phi0", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", 
    RowBox[{"i", "<=", "xgr"}], ",", 
    RowBox[{"i", "++"}], ",", 
    RowBox[{"AppendTo", "[", 
     RowBox[{"phi0", ",", 
      RowBox[{"IC2", "[", 
       RowBox[{"xGrid", "[", 
        RowBox[{"[", "i", "]"}], "]"}], "]"}]}], "]"}]}], "]"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"phi", "=", "phi0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"results", "=", 
    RowBox[{"{", "phi", "}"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"t", "=", "1"}], ",", 
     RowBox[{"t", "<=", 
      RowBox[{"tgr", "-", "1"}]}], ",", 
     RowBox[{"t", "++"}], ",", 
     RowBox[{
      RowBox[{"phiNew", "=", "phi"}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "2"}], ",", 
        RowBox[{"i", "<=", 
         RowBox[{"xgr", "-", "1"}]}], ",", 
        RowBox[{"i", "++"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"phiNew", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "=", 
          RowBox[{
           RowBox[{"phi", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "+", 
           RowBox[{"nu", "*", 
            RowBox[{"dt", "/", 
             RowBox[{"dx", "^", "2"}]}], "*", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"phi", "[", 
               RowBox[{"[", 
                RowBox[{"i", "-", "1"}], "]"}], "]"}], "-", 
              RowBox[{"2", "*", 
               RowBox[{"phi", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], "+", 
              RowBox[{"phi", "[", 
               RowBox[{"[", 
                RowBox[{"i", "+", "1"}], "]"}], "]"}]}], ")"}]}]}]}], ";"}]}],
        "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"phiNew", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "=", 
         RowBox[{
          RowBox[{"phi", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "+", 
          RowBox[{"nu", "*", 
           RowBox[{"dt", "/", 
            RowBox[{"dx", "^", "2"}]}], "*", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"phi", "[", 
              RowBox[{"[", 
               RowBox[{"xgr", "-", "1"}], "]"}], "]"}], "-", 
             RowBox[{"2", "*", 
              RowBox[{"phi", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], "+", 
             RowBox[{"phi", "[", 
              RowBox[{"[", "2", "]"}], "]"}]}], ")"}]}]}]}], " ", 
        RowBox[{"(*", "PBC", "*)"}], ";"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"phiNew", "[", 
          RowBox[{"[", "xgr", "]"}], "]"}], "=", 
         RowBox[{"phiNew", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], 
        RowBox[{"(*", "PBC", "*)"}], ";"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"phiNew", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "=", 
       RowBox[{
        RowBox[{"phi", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "+", 
        RowBox[{"nu", "*", 
         RowBox[{"dt", "/", 
          RowBox[{"dx", "^", "2"}]}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"phi", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "-", 
           RowBox[{"2", "*", 
            RowBox[{"phi", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], "+", 
           RowBox[{"phi", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ")"}]}]}]}], " ", 
      RowBox[{"(*", "Neumann", "*)"}], ";", 
      RowBox[{
       RowBox[{"phiNew", "[", 
        RowBox[{"[", "xgr", "]"}], "]"}], "=", 
       RowBox[{"phiNew", "[", 
        RowBox[{"[", 
         RowBox[{"xgr", "-", "1"}], "]"}], "]"}]}], 
      RowBox[{"(*", "Neumann", "*)"}], ";", "\[IndentingNewLine]", 
      RowBox[{"phi", "=", "phiNew"}], ";", "\[IndentingNewLine]", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"results", ",", "phi"}], "]"}], ";"}]}], "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
